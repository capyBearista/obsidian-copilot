# Enforce LF line endings for shell scripts and husky hooks
# Prevents CRLF corruption on Windows/WSL with core.autocrlf=true
.husky/* text eol=lf
*.sh text eol=lf

# Source files should always be LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
